---
import Layout from '@/layouts/Layout.astro';
import WishBoard from '@/components/wishlist/WishBoard';

const flowSteps = [
  { icon: '✨', label: '許願' },
  { icon: '🎯', label: '願望池' },
  { icon: '🙋', label: '認領' },
  { icon: '🔨', label: '實作' },
  { icon: '👀', label: '檢視' },
  { icon: '✅', label: '完成' },
];
---

<style>
  .wish-tree-glow {
    filter: drop-shadow(0 0 24px rgba(0, 245, 160, 0.5)) drop-shadow(0 0 48px rgba(0, 245, 160, 0.25));
  }

  [data-theme="light"] .wish-tree-glow {
    filter: drop-shadow(0 0 16px rgba(0, 245, 160, 0.25)) drop-shadow(0 0 32px rgba(0, 245, 160, 0.12));
  }
</style>

<Layout title="許願樹" description="許下願望，等待夥伴來實現">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Header -->
    <div class="text-center mb-12">
      <div class="relative inline-block mb-4">
        <span class="text-8xl block leading-none select-none wish-tree-glow">🌳</span>
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-3">
        <span style="background: linear-gradient(135deg, var(--color-neon-green), var(--color-neon-blue)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
          許願樹
        </span>
      </h1>
      <p class="text-lg text-[var(--color-text-secondary)]">許下願望，等待夥伴來實現</p>
    </div>

    <!-- Dynamic Board -->
    <WishBoard client:load />

    <!-- Flow Explanation -->
    <section class="mt-12 mb-12">
      <h2 class="text-xl font-semibold mb-5 flex items-center gap-2">
        <span>🔄</span>
        <span class="text-[var(--color-text-primary)]">許願流程</span>
      </h2>
      <div class="glass rounded-2xl p-6 glow-neon">
        <div class="flex flex-wrap items-center justify-center gap-2 sm:gap-0">
          {flowSteps.map((step, idx) => (
            <>
              <div class="flex flex-col items-center gap-1 px-3 py-2">
                <span class="text-2xl">{step.icon}</span>
                <span class="text-xs font-medium text-[var(--color-text-secondary)]">{step.label}</span>
              </div>
              {idx < flowSteps.length - 1 && (
                <span class="text-[var(--color-neon-green)] opacity-60 text-xl font-light hidden sm:block">→</span>
              )}
            </>
          ))}
        </div>
      </div>
    </section>

  </div>
</Layout>
