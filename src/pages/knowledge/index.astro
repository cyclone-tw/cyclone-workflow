---
import Layout from '@/layouts/Layout.astro';
import KnowledgeBoard from '@/components/knowledge/KnowledgeBoard';
---

<Layout title="知識庫" description="團隊共享的 AI 工作流知識庫">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl sm:text-5xl font-bold mb-3">
        <span class="text-3xl sm:text-4xl mr-2">📚</span>
        <span class="gradient-text">知識庫</span>
      </h1>
      <p class="text-[var(--color-text-secondary)] text-lg">團隊共享的 AI 工作流知識</p>
    </div>

    <!-- Dynamic Board -->
    <KnowledgeBoard client:load />

  </div>
</Layout>
