---
import Layout from '@/layouts/Layout.astro';
import { MEMBERS } from '@/lib/constants';
---

<Layout title="團隊" description="AI 工作流共學團成員介紹">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Page Header -->
    <div class="text-center mb-14">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="gradient-text">👥 共學團成員</span>
      </h1>
      <p class="text-[var(--color-text-secondary)] text-lg max-w-2xl mx-auto">
        六位成員，一起探索 AI 工作流的無限可能。四週共學，互相激盪，共同成長。
      </p>
    </div>

    <!-- Member Cards Grid -->
    <section class="mb-20">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {MEMBERS.map((member) => (
          <div
            class="glass card-hover rounded-2xl p-6 flex flex-col items-center text-center group cursor-default"
            style={`--member-color: ${member.color};`}
          >
            <!-- Avatar with glow ring -->
            <div
              class="relative mb-5"
              style={`filter: drop-shadow(0 0 16px ${member.color}66);`}
            >
              <div
                class="w-20 h-20 rounded-full flex items-center justify-center text-4xl border-2 transition-all duration-300 group-hover:scale-110"
                style={`border-color: ${member.color}; background: ${member.color}1A; box-shadow: 0 0 0 0 ${member.color}44; transition: box-shadow 0.3s ease, transform 0.3s ease;`}
              >
                {member.avatar}
              </div>
            </div>

            <!-- Name + Tag -->
            <h2 class="text-xl font-bold text-[var(--color-text-primary)] mb-1">
              {member.name}
              <span class="text-sm font-normal ml-1" style={`color: ${member.color};`}>
                {member.tag}
              </span>
            </h2>

            <!-- Role Badge -->
            <span
              class="mt-2 inline-block px-3 py-1 rounded-full text-xs font-semibold tracking-wide border"
              style={`color: ${member.color}; border-color: ${member.color}44; background: ${member.color}18;`}
            >
              {member.role}
            </span>
          </div>
        ))}
      </div>
    </section>

    <!-- Project Exchange Section (Week 3) -->
    <section class="mb-20">
      <div class="glass rounded-2xl p-8 sm:p-10">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)]">
            🔄 Project 交換機制
          </h2>
          <span class="self-start sm:self-auto inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-[var(--color-neon-green)]/10 text-[var(--color-neon-green)] border border-[var(--color-neon-green)]/30">
            <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-neon-green)] animate-pulse inline-block"></span>
            第三週開放
          </span>
        </div>

        <p class="text-[var(--color-text-secondary)] text-base leading-relaxed mb-10 max-w-3xl">
          第三週起，每位成員將透過隨機抽籤配對，接手夥伴的專案進行理解與改造。
          這是一場換位思考的實驗——讀懂別人的 AI 工作流，再用自己的方式重新演繹，最後一起分享成果。
        </p>

        <!-- Flow Steps -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
          {[
            { step: '01', icon: '🎲', label: '抽籤配對', desc: '隨機分配交換夥伴' },
            { step: '02', icon: '📖', label: '閱讀理解', desc: '深入研究夥伴的工作流' },
            { step: '03', icon: '🔧', label: '改造實作', desc: '加入自己的創意與優化' },
            { step: '04', icon: '🎤', label: '成果分享', desc: '向全團展示你的詮釋' },
          ].map((item) => (
            <div class="relative flex flex-col items-center text-center p-4 rounded-xl bg-[var(--color-bg-card-hover)] border border-[var(--color-border)]">
              <span class="absolute top-3 right-3 text-[10px] font-bold text-[var(--color-text-muted)]">
                {item.step}
              </span>
              <div class="text-3xl mb-3 mt-1">{item.icon}</div>
              <p class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">{item.label}</p>
              <p class="text-xs text-[var(--color-text-muted)] leading-snug">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Showcase Section (Week 4) -->
    <section>
      <div class="glass rounded-2xl p-8 sm:p-10">
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 mb-6">
          <h2 class="text-2xl sm:text-3xl font-bold text-[var(--color-text-primary)]">
            🏆 成果展示
          </h2>
          <span class="self-start sm:self-auto inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-[var(--color-primary)]/10 text-[var(--color-primary-light)] border border-[var(--color-primary)]/30">
            第四週 · 即將登場
          </span>
        </div>

        <!-- Empty State -->
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="text-6xl mb-5 opacity-40">🏅</div>
          <p class="text-[var(--color-text-muted)] text-base">
            第四週展示成果，敬請期待！
          </p>
          <p class="text-[var(--color-text-muted)] text-sm mt-2 opacity-70">
            2026 年 4 月 28 日起開放
          </p>
        </div>
      </div>
    </section>

  </div>
</Layout>

<style>
  .card-hover:hover > div:first-child > div {
    box-shadow: 0 0 24px var(--member-color, #6C63FF);
  }

  [data-theme="light"] .card-hover > div:first-child > div {
    filter: drop-shadow(0 0 8px var(--member-color, #6C63FF));
  }
</style>
