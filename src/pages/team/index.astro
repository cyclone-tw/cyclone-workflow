---
import Layout from '@/layouts/Layout.astro';
import { MEMBERS, ROLE_GROUPS } from '@/lib/constants';

// Group members by role
const grouped = ROLE_GROUPS.map((group) => ({
  ...group,
  members: MEMBERS.filter((m) => m.groupRole === group.key),
})).filter((g) => g.members.length > 0);

const memberCount = MEMBERS.length;
---

<Layout title="團隊" description="AI 工作流共學團成員介紹">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Page Header -->
    <div class="text-center mb-14">
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="gradient-text">👥 共學團成員</span>
      </h1>
      <p class="text-[var(--color-text-secondary)] text-lg max-w-2xl mx-auto">
        {memberCount} 位成員，一起探索 AI 工作流的無限可能。三週共學，互相激盪，共同成長。
      </p>
    </div>

    <!-- Role Groups -->
    {grouped.map((group) => (
      <section class="mb-16">
        <!-- Group Header -->
        <div class="flex items-center gap-3 mb-6">
          <div
            class="w-10 h-10 rounded-xl flex items-center justify-center text-xl"
            style={`background: ${group.color}20; border: 1px solid ${group.color}40;`}
          >
            {group.icon}
          </div>
          <div>
            <h2 class="text-xl font-bold text-[var(--color-text-primary)]">{group.label}</h2>
            <p class="text-xs text-[var(--color-text-muted)]">{group.members.length} 人</p>
          </div>
          <div class="flex-1 h-px bg-[var(--color-border)] ml-4"></div>
        </div>

        <!-- Member Cards Grid -->
        <div class={`grid gap-4 ${
          group.key === 'companion'
            ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5'
            : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'
        }`}>
          {group.members.map((member) => (
            <div
              class="glass card-hover rounded-2xl p-5 flex flex-col items-center text-center group cursor-default"
              style={`--member-color: ${member.color};`}
            >
              <!-- Avatar with glow ring -->
              <div
                class="relative mb-4"
                style={`filter: drop-shadow(0 0 12px ${member.color}44);`}
              >
                <div
                  class="w-16 h-16 rounded-full flex items-center justify-center text-3xl border-2 transition-all duration-300 group-hover:scale-110"
                  style={`border-color: ${member.color}; background: ${member.color}1A;`}
                >
                  {member.avatar}
                </div>
              </div>

              <!-- Name + Tag -->
              <h3 class="text-base font-bold text-[var(--color-text-primary)] mb-1">
                {member.name}
                {member.tag && (
                  <span class="text-xs font-normal ml-1" style={`color: ${member.color};`}>
                    {member.tag}
                  </span>
                )}
              </h3>

              <!-- Role Badge -->
              <span
                class="inline-block px-2.5 py-0.5 rounded-full text-[10px] font-semibold tracking-wide border mb-2"
                style={`color: ${member.color}; border-color: ${member.color}44; background: ${member.color}18;`}
              >
                {member.role}
              </span>

              <!-- Intro -->
              {member.intro && (
                <p class="text-xs text-[var(--color-text-muted)] leading-relaxed mt-1 line-clamp-2">
                  {member.intro}
                </p>
              )}
            </div>
          ))}
        </div>
      </section>
    ))}

  </div>
</Layout>

<style>
  .card-hover:hover > div:first-child > div {
    box-shadow: 0 0 20px var(--member-color, #6C63FF);
  }

  [data-theme="light"] .card-hover > div:first-child > div {
    filter: drop-shadow(0 0 8px var(--member-color, #6C63FF));
  }

  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
