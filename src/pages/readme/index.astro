---

<Layout title="使用說明" description="Cyclone 隊長 × 生活黑客共學團 — 網站使用說明與學習資源">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Header -->
    <div class="mb-14 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-medium mb-5 border"
        style="background: color-mix(in srgb, var(--color-primary) 15%, transparent); border-color: color-mix(in srgb, var(--color-primary) 30%, transparent); color: var(--color-primary-light);">
        2026 Q2・四週共學計畫
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4">
        <span class="text-4xl sm:text-5xl mr-3">📖</span>
        <span class="gradient-text">使用說明</span>
      </h1>
      <p class="text-[var(--color-text-secondary)] text-lg max-w-xl mx-auto leading-relaxed">
        歡迎加入 <span class="text-[var(--color-text-primary)] font-medium">Cyclone 隊長 × 生活黑客共學團</span>！<br />
        這份說明幫你快速上手所有功能，開啟四週的 AI 工作流旅程。
      </p>
    </div>

    <!-- What is this site -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-6 rounded-full" style="background: var(--color-primary);"></span>
        <h2 class="text-xl font-bold text-[var(--color-text-primary)]">這個網站是什麼？</h2>
      </div>
      <div class="glass rounded-2xl p-7 mb-5" style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 12%, transparent) 0%, color-mix(in srgb, var(--color-neon-blue) 8%, transparent) 100%); border-color: color-mix(in srgb, var(--color-primary) 25%, transparent);">
        <p class="text-[var(--color-text-secondary)] leading-relaxed mb-5 text-base">
          這是一個專為 <strong class="text-[var(--color-text-primary)]">六人小型共學團</strong> 設計的專屬平台。六位成員將在四週內，從零開始打造屬於自己的 AI 工作流，互相學習、互相督促、互相幫助。
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          {[
            { icon: '🌀', title: '打造個人 AI 工作流', desc: '四週從環境建置到成果發表，每人產出一套可實際運用的個人工作流。' },
            { icon: '🤖', title: '專屬 AI 管家', desc: '每位成員都有專屬的 Cyclone 管家，具備長期記憶，記得你的偏好與進度。' },
            { icon: '🌳', title: '互助共學機制', desc: '透過許願樹、Project 交換、知識庫，把個人學習變成集體智慧。' },
          ].map((item) => (
            <div class="rounded-xl p-4 border" style="background: var(--color-glass-bg); border-color: var(--color-border);">
              <div class="text-2xl mb-2">{item.icon}</div>
              <h3 class="text-sm font-semibold text-[var(--color-text-primary)] mb-1">{item.title}</h3>
              <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Page Guide -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-6 rounded-full" style="background: var(--color-neon-blue);"></span>
        <h2 class="text-xl font-bold text-[var(--color-text-primary)]">頁面導覽</h2>
        <span class="text-xs px-2 py-0.5 rounded-full font-medium border"
          style="background: var(--color-info-neon-bg); color: var(--color-info-neon-text); border-color: color-mix(in srgb, var(--color-neon-blue) 30%, transparent);">
          {pages.length} 個頁面
        </span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {pages.map((page) => (
          <a href={page.href} class="glass rounded-xl p-5 card-hover flex flex-col gap-3 group" style={`border-left: 3px solid ${page.color};`}>
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-2.5">
                <span class="text-2xl">{page.icon}</span>
                <span class="font-semibold text-[var(--color-text-primary)] group-hover:text-white transition-colors">{page.title}</span>
              </div>
              <code class="text-[10px] px-2 py-0.5 rounded font-mono shrink-0" style={`background: ${page.color}15; color: ${page.color};`}>
                {page.href}
              </code>
            </div>
            <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{page.description}</p>
            <div class="flex flex-wrap gap-1.5 pt-1">
              {page.tips.map((tip) => (
                <span class="text-xs px-2 py-0.5 rounded-full border" style={`background: ${page.color}10; color: ${page.color}CC; border-color: ${page.color}25;`}>
                  {tip}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- How to Interact -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-6 rounded-full" style="background: var(--color-neon-green);"></span>
        <h2 class="text-xl font-bold text-[var(--color-text-primary)]">功能使用方式</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {howToItems.map((item) => (
          <div class="glass rounded-xl p-6 flex flex-col gap-4">
            <div class="flex items-center gap-3">
              <span class="text-2xl">{item.icon}</span>
              <h3 class="font-semibold text-[var(--color-text-primary)] text-sm leading-snug">{item.title}</h3>
            </div>
            <ol class="flex flex-col gap-2">
              {item.steps.map((step, i) => (
                <li class="flex items-start gap-3 text-sm text-[var(--color-text-secondary)]">
                  <span class="shrink-0 w-5 h-5 rounded-full flex items-center justify-center text-[10px] font-bold mt-0.5"
                    style={`background: ${item.color}20; color: ${item.color};`}>
                    {i + 1}
                  </span>
                  <span class="leading-relaxed">{step}</span>
                </li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </section>

    <!-- Four-Week Journey -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-6 rounded-full" style="background: var(--color-accent);"></span>
        <h2 class="text-xl font-bold text-[var(--color-text-primary)]">四週共學旅程</h2>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {WEEKS.map((week, i) => {
          const colors = [
            'var(--color-primary)',
            'var(--color-neon-blue)',
            'var(--color-neon-green)',
            'var(--color-accent)',
          ];
          const color = colors[i] ?? colors[0];
          const dateObj = new Date(week.start);
          const dateStr = `${dateObj.getMonth() + 1}/${dateObj.getDate()}`;
          return (
            <div class="glass rounded-xl p-5 flex flex-col gap-3 text-center" style={`border-top: 3px solid ${color};`}>
              <div class="text-xs font-medium" style={`color: ${color};`}>Week {week.num}</div>
              <div class="text-2xl font-bold text-[var(--color-text-primary)]">{week.title}</div>
              <div class="text-xs text-[var(--color-text-secondary)] leading-relaxed">{week.subtitle}</div>
              <div class="text-xs text-[var(--color-text-muted)] mt-auto pt-2 border-t border-[var(--color-border)]">
                {dateStr} 啟動
              </div>
            </div>
          );
        })}
      </div>
      <div class="mt-4 glass rounded-xl p-4 flex items-start gap-3">
        <span class="text-xl shrink-0">💡</span>
        <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
          每週一為新的一週開始。第三週（4/21）會進行 <strong class="text-[var(--color-text-primary)]">Project 抽籤交換</strong>，你的工作流會換給隊友繼續發展，你也會接手別人的成果——這是共學精華！
        </p>
      </div>
    </section>

    <!-- Learning Resources -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-6 rounded-full" style="background: var(--color-primary);"></span>
        <h2 class="text-xl font-bold text-[var(--color-text-primary)]">學習資源</h2>
        <span class="text-xs text-[var(--color-text-muted)]">精選外部學習連結</span>
      </div>

      <div class="flex flex-col gap-10">
        {resources.map((group) => (
          <div>
            <div class="flex items-center gap-2.5 mb-4">
              <span class="text-xl">{group.icon}</span>
              <h3 class="text-base font-bold text-[var(--color-text-primary)]">{group.category}</h3>
              <span class="w-full h-px ml-2" style={`background: linear-gradient(90deg, ${group.color}40, transparent);`}></span>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {group.items.map((item) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="glass rounded-xl p-4 card-hover flex flex-col gap-2.5 group"
                >
                  <div class="flex items-start justify-between gap-2">
                    <span class="text-sm font-semibold text-[var(--color-text-primary)] group-hover:text-white transition-colors leading-snug">
                      {item.title}
                    </span>
                    <span class="text-xs px-2 py-0.5 rounded-full shrink-0 font-medium border"
                      style={`background: ${group.color}12; color: ${group.color}; border-color: ${group.color}25;`}>
                      {item.tag}
                    </span>
                  </div>
                  <p class="text-xs text-[var(--color-text-secondary)] leading-relaxed">{item.description}</p>
                  <div class="flex items-center gap-1 text-xs mt-auto" style={`color: ${group.color};`}>
                    <span class="truncate max-w-[220px] opacity-70">{item.url.replace(/^https?:\/\//, '')}</span>
                    <svg class="w-3 h-3 shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mb-16">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-1 h-6 rounded-full" style="background: var(--color-neon-green);"></span>
        <h2 class="text-xl font-bold text-[var(--color-text-primary)]">常見問題 FAQ</h2>
      </div>
      <div class="flex flex-col gap-3">
        {faqs.map((faq, i) => (
          <details class="glass rounded-xl group">
            <summary class="flex items-center justify-between px-5 py-4 cursor-pointer list-none select-none">
              <div class="flex items-center gap-3">
                <span class="text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center shrink-0"
                  style="background: color-mix(in srgb, var(--color-neon-green) 15%, transparent); color: var(--color-neon-green);">
                  Q
                </span>
                <span class="text-sm font-medium text-[var(--color-text-primary)]">{faq.q}</span>
              </div>
              <svg class="w-4 h-4 text-[var(--color-text-muted)] transition-transform group-open:rotate-180 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 pt-1">
              <div class="flex items-start gap-3">
                <span class="text-xs font-bold w-6 h-6 rounded-full flex items-center justify-center shrink-0 mt-0.5"
                  style="background: color-mix(in srgb, var(--color-primary) 15%, transparent); color: var(--color-primary-light);">
                  A
                </span>
                <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">{faq.a}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- CTA Banner -->
    <div class="relative overflow-hidden rounded-2xl p-8 text-center"
      style="background: linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 15%, transparent) 0%, color-mix(in srgb, var(--color-neon-green) 10%, transparent) 100%); border: 1px solid color-mix(in srgb, var(--color-primary) 30%, transparent);">
      <div class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse at 50% 0%, color-mix(in srgb, var(--color-primary) 12%, transparent) 0%, transparent 70%);"></div>
      <div class="relative z-10">
        <div class="text-4xl mb-3">🌀</div>
        <h3 class="text-xl font-bold text-[var(--color-text-primary)] mb-2">準備好了嗎？</h3>
        <p class="text-[var(--color-text-secondary)] mb-6 text-sm">四週後，你將擁有一套真正屬於自己的 AI 工作流。</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href="/dashboard"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white transition-all hover:opacity-90 active:scale-95"
            style="background: linear-gradient(135deg, var(--color-primary), var(--color-neon-blue));">
            <span>📊</span>
            前往儀表板
          </a>
          <a href="/agent"
            class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm transition-all hover:bg-white/10 active:scale-95 border"
            style="border-color: var(--color-border); color: var(--color-text-secondary);">
            <span>🤖</span>
            找管家聊聊
          </a>
        </div>
      </div>
    </div>

  </div>
</Layout>
