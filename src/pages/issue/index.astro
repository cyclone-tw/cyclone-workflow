---
import Layout from '@/layouts/Layout.astro';
import IssueBoard from '@/components/issues/IssueBoard';
---

<Layout title="Issues" description="提出問題、功能建議，追蹤修復進度">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">
        <span class="gradient-text">📋 Issues</span>
      </h1>
      <p class="text-[var(--color-text-secondary)] max-w-lg mx-auto">
        提出問題、功能建議，追蹤修復進度
      </p>
    </div>

    <!-- Issue Board -->
    <IssueBoard client:load />

    <!-- Info section -->
    <div
      class="mt-10 rounded-xl p-5 border"
      style="background: var(--color-info-primary-bg); border-color: var(--color-info-primary-border);"
    >
      <div class="flex items-start gap-3">
        <span class="text-xl mt-0.5">💡</span>
        <div>
          <h3 class="text-sm font-bold mb-1" style="color: var(--color-primary-light);">Issues 與 Changelog 的關聯</h3>
          <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
            Issues 會對應到 Changelog 版本，讓你知道問題在哪個版本修復。
            當一個 Issue 被解決後，會標記對應的版本號，你可以前往
            <a href="/changelog" class="font-semibold transition-colors" style="color: var(--color-primary);" onmouseover="this.style.color='var(--color-primary-light)'" onmouseout="this.style.color='var(--color-primary)'">Changelog</a>
            查看該版本的完整更新內容。
          </p>
        </div>
      </div>
    </div>

  </div>
</Layout>
