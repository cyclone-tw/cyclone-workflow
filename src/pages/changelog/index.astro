---
import Layout from '@/layouts/Layout.astro';
import { VERSION } from '@/lib/version';
import { CHANGELOG } from '@/lib/changelog';
---

<Layout title="Changelog" description="網站更新紀錄">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3">
        <span class="gradient-text">📋 Changelog</span>
      </h1>
      <p class="text-[var(--color-text-secondary)]">
        網站更新紀錄 — 目前版本
        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-mono bg-[var(--color-primary)]/20 text-[var(--color-primary-light)] ml-1">
          {VERSION}
        </span>
      </p>
    </div>

    <!-- Timeline -->
    <div class="relative">
      <!-- Vertical line -->
      <div class="absolute left-4 top-0 bottom-0 w-px bg-[var(--color-border)]"></div>

      <div class="space-y-6">
        {CHANGELOG.map((entry, i) => (
          <div class="relative pl-12">
            <!-- Dot -->
            <div
              class="absolute left-2.5 top-1.5 w-3 h-3 rounded-full border-2"
              style={`
                background: ${i === 0 ? 'var(--color-neon-green)' : 'var(--color-bg-card)'};
                border-color: ${i === 0 ? 'var(--color-neon-green)' : 'var(--color-border)'};
                ${i === 0 ? 'box-shadow: 0 0 8px var(--color-neon-green);' : ''}
              `}
            ></div>

            <div
              class="glass rounded-xl p-5"
              style={i === 0 ? 'border-color: var(--color-neon-green); border-width: 1px;' : ''}
            >
              <div class="flex items-center justify-between mb-3">
                <span class="text-sm font-mono font-bold text-[var(--color-text-primary)]">
                  {entry.version}
                  {i === 0 && (
                    <span class="ml-2 text-xs px-2 py-0.5 rounded-full bg-[var(--color-neon-green)]/20 text-[var(--color-neon-green)]">
                      latest
                    </span>
                  )}
                </span>
                <span class="text-xs text-[var(--color-text-muted)]">{entry.date}</span>
              </div>
              <ul class="space-y-1.5">
                {entry.changes.map(change => {
                  const isFix = change.startsWith('fix:');
                  const isFeat = change.startsWith('feat:');
                  const color = isFix ? 'var(--color-accent)' : isFeat ? 'var(--color-neon-green)' : 'var(--color-text-muted)';
                  const label = isFix ? 'FIX' : isFeat ? 'NEW' : '•';
                  return (
                    <li class="flex items-start gap-2 text-sm">
                      <span
                        class="text-xs font-mono px-1.5 py-0.5 rounded shrink-0 mt-0.5"
                        style={`background: ${color}15; color: ${color};`}
                      >
                        {label}
                      </span>
                      <span style="color: var(--color-text-secondary);">
                        {change.replace(/^(fix|feat):\s*/, '')}
                      </span>
                    </li>
                  );
                })}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>
